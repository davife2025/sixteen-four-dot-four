{
  "name": "sixteen",
  "private": true,
  "version": "0.0.1",
  "description": "Sixteen — AI agent meme trading platform on BNB Chain",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "agent:start": "turbo run start --filter=@sixteen/agent",
    "api:start": "turbo run start --filter=@sixteen/api",
    "web:dev": "turbo run dev --filter=@sixteen/web",
    "db:migrate": "pnpm --filter @sixteen/db migrate",
    "db:generate": "pnpm --filter @sixteen/db generate"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
