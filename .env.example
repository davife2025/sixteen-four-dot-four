# ============================================================
# SIXTEEN — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── Kimi K2 via Hugging Face ──────────────────────────────
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ──────────────────────────────────────────────
# Get from: https://app.supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── BNB Testnet (BSC Testnet) ─────────────────────────────
# Public testnet RPC — no key needed for this one
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
# Your agent's wallet private key (hex, no 0x prefix needed)
# Fund from: https://testnet.binance.org/faucet-smart
AGENT_PRIVATE_KEY=your_hex_private_key_here

# ── four.meme API (uses same wallet, no separate key) ─────
# The agent wallet signs requests — no additional API key

# ── Video Generation — ModelsLab (Kling 2.6) ─────────────
# Get from: https://modelslab.com/dashboard/api
MODELSLAB_API_KEY=your_modelslab_key_here

# ── Static Meme Generation — Supermeme.ai ────────────────
# Get from: https://supermeme.ai/account → API tab
SUPERMEME_API_KEY=your_supermeme_key_here

# ── Blockchain data — Bitquery (real-time events) ─────────
# Get from: https://bitquery.io → API Key
BITQUERY_API_KEY=your_bitquery_key_here

# ── Next.js Web App (public vars, safe to expose) ─────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_BSC_TESTNET_CHAIN_ID=97
NEXT_PUBLIC_FOURMEME_CONTRACT=0x5c952063c7fc8610FFDB798152D69F0B9550762b
